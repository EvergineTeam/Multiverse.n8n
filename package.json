{
  "name": "@plainconcepts/n8n-nodes-compactifai",
  "version": "0.1.1",
  "description": "n8n community node for Compactifai API integration",
  "license": "MIT",
  "homepage": "",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Rafael Caro",
    "email": "rafael.caro@plainconcepts.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EvergineTeam/Multiverse.n8n.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/MultiverseCompactifaiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MultiverseCompactifAi/MultiverseCompactifAi.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@langchain/openai": "^1.1.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
